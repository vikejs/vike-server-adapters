{
  "name": "vikejs-servers-workspace",
  "private": true,
  "version": "0.0.1",
  "description": "Server adapters for Vike",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "typecheck": "pnpm -r run typecheck",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "changeset publish",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.19.43",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.34.4"
}
